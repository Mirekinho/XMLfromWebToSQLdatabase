<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:XMLfromWebToSQLdatabase.ViewModels"
		mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
		x:Class="XMLfromWebToSQLdatabase.MainWindow"
        x:DataType="vm:MainWindowViewModel"
		Title="XMLfromWebToSQLdatabase"
        Width="600" Height="500">
	<StackPanel Margin="15" Spacing="10">
		<TextBlock Text="Enter the URL with raw XML file:" />

		<TextBox Watermark="Insert valid URL"
				 Text="{Binding XmlUrl}" />
		<Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,10"/>

		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="Select time interval to the next XML retrieval:" />
			<TimePicker ClockIdentifier="24HourClock"
						MinuteIncrement="15"
						SelectedTime="{Binding RetrievalInterval}"
						Margin="0,-5,0,0"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="Next XML retrieval attempt scheduled at:" />
			<TextBlock Text="{Binding NextRetrievalText}" />
		</StackPanel>

		<Button Content="Immediate XML retrieval"
				Padding="10"
				HorizontalAlignment="Stretch"
				HorizontalContentAlignment="Center"
				Command="{Binding StartRetrievalCommand}" />
		<Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0"/>
		<TextBlock Text="XML Retrieval Log:" />

		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<ListBox ItemsSource="{Binding LogEntries}" Height="200" />
		</ScrollViewer>
    </StackPanel>
</Window>
